<div class="fcx-screen">
  <div class="fcx-topbar">
    <div class="fcx-title">Calendar</div>
    <div class="fcx-synced">Synced: {{ synced_label | default: "just now" }}</div>
  </div>

  <div class="fcx-week" style="--days: {{ day_count }};">
    <div class="fcx-corner"></div>
    {% for day in days %}
      <div class="fcx-day-head {% if day.is_today %}fcx-today{% endif %}">
        <span>{{ day.label }}</span>
      </div>
    {% endfor %}

    <div class="fcx-all-day-label">all-day</div>
    {% for day in days %}
      <div class="fcx-all-day-cell">
        {% for event in day.all_day_events limit:3 %}
          <div class="fcx-all-day-event">
            {% if show_calendar_names %}<b>{{ event.calendar }}</b> {% endif %}{{ event.title }}
          </div>
        {% endfor %}
        {% if day.all_day_events.size > 3 %}
          <div class="fcx-more">+{{ day.all_day_events.size | minus: 3 }}</div>
        {% endif %}
      </div>
    {% endfor %}

    <div class="fcx-time-labels">
      {% for hour in hours %}
        <div class="fcx-hour-label" style="top: {{ hour.top_pct }}%;">{{ hour.label }}</div>
      {% endfor %}
    </div>

    {% for day in days %}
      <div class="fcx-day-column">
        {% for hour in hours %}
          <div class="fcx-hour-line" style="top: {{ hour.top_pct }}%;"></div>
        {% endfor %}
        {% for event in day.timed_events %}
          <div
            class="fcx-event"
            style="top: {{ event.top_pct }}%; height: {{ event.height_pct }}%; left: {{ event.left_pct }}%; width: {{ event.width_pct }}%;"
          >
            <div class="fcx-event-title">{{ event.title }}</div>
            {% if show_calendar_names %}<div class="fcx-event-cal">{{ event.calendar }}</div>{% endif %}
          </div>
        {% endfor %}
      </div>
    {% endfor %}
  </div>
</div>

<style>
  * {
    box-sizing: border-box;
  }

  .fcx-screen {
    width: 100%;
    height: 100%;
    min-height: 900px;
    padding: 16px 22px;
    color: #111;
    background: #fff;
    font-family: Arial, Helvetica, sans-serif;
    overflow: hidden;
    display: grid;
    grid-template-rows: 58px minmax(0, 1fr);
  }

  .fcx-topbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-bottom: 5px solid #111;
    min-width: 0;
  }

  .fcx-title {
    font-size: 42px;
    line-height: 48px;
    font-weight: 800;
  }

  .fcx-synced {
    border: 3px solid #111;
    border-radius: 18px;
    padding: 7px 18px;
    font-size: 24px;
    line-height: 28px;
    font-weight: 800;
    white-space: nowrap;
  }

  .fcx-week {
    --time-width: 82px;
    display: grid;
    grid-template-columns: var(--time-width) repeat(var(--days), minmax(0, 1fr));
    grid-template-rows: 72px 104px minmax(0, 1fr);
    border-left: 5px solid #111;
    border-bottom: 5px solid #111;
    min-width: 0;
    min-height: 0;
  }

  .fcx-corner,
  .fcx-day-head,
  .fcx-all-day-label,
  .fcx-all-day-cell,
  .fcx-time-labels,
  .fcx-day-column {
    border-right: 3px solid #555;
    min-width: 0;
  }

  .fcx-corner,
  .fcx-day-head {
    border-bottom: 5px solid #111;
  }

  .fcx-day-head {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 6px;
    font-size: 28px;
    line-height: 34px;
    font-weight: 800;
    overflow: hidden;
    white-space: nowrap;
  }

  .fcx-day-head.fcx-today span {
    color: #fff;
    background: #111;
    border-radius: 22px;
    padding: 8px 18px;
  }

  .fcx-all-day-label {
    border-bottom: 5px solid #111;
    padding-top: 38px;
    text-align: center;
    font-size: 17px;
    line-height: 20px;
    font-weight: 800;
    text-transform: uppercase;
  }

  .fcx-all-day-cell {
    border-bottom: 5px solid #111;
    padding: 7px;
    overflow: hidden;
  }

  .fcx-all-day-event,
  .fcx-more {
    height: 26px;
    margin-bottom: 5px;
    padding: 2px 8px;
    border: 3px solid #111;
    border-radius: 12px;
    background: #ddd;
    font-size: 18px;
    line-height: 20px;
    overflow: hidden;
    white-space: nowrap;
    text-overflow: ellipsis;
  }

  .fcx-more {
    background: #fff;
    font-weight: 800;
    text-align: center;
  }

  .fcx-time-labels,
  .fcx-day-column {
    position: relative;
    min-height: 0;
  }

  .fcx-hour-label {
    position: absolute;
    right: 10px;
    transform: translateY(-50%);
    color: #222;
    font-size: 22px;
    line-height: 26px;
    font-weight: 800;
  }

  .fcx-hour-line {
    position: absolute;
    left: 0;
    right: 0;
    border-top: 2px solid #c4c4c4;
  }

  .fcx-event {
    position: absolute;
    min-height: 28px;
    padding: 6px 8px;
    border: 3px solid #111;
    border-radius: 12px;
    background: #d0d0d0;
    overflow: hidden;
  }

  .fcx-event-title {
    font-size: 21px;
    line-height: 25px;
    font-weight: 800;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .fcx-event-cal {
    margin-top: 3px;
    font-size: 17px;
    line-height: 20px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
</style>
