<div class="fcx-screen">
  <div class="fcx-topbar">
    <div class="fcx-title">Calendar</div>
  </div>

  <div class="fcx-week" style="--days: {{ day_count }};">
    <div class="fcx-corner"></div>
    {% for day in days %}
      <div class="fcx-day-head {% if day.is_today %}fcx-today{% endif %}">
        <span>{{ day.label }}</span>
      </div>
    {% endfor %}

    <div class="fcx-all-day-label">all-day</div>
    {% for day in days %}
      <div class="fcx-all-day-cell">
        {% for event in day.all_day_events limit:3 %}
          <div class="fcx-all-day-event">
            {% if show_calendar_names %}<b>{{ event.calendar }}</b> {% endif %}{{ event.title }}
          </div>
        {% endfor %}
        {% if day.all_day_events.size > 3 %}
          <div class="fcx-more">+{{ day.all_day_events.size | minus: 3 }}</div>
        {% endif %}
      </div>
    {% endfor %}

    <div class="fcx-time-labels">
      {% for hour in hours %}
        <div class="fcx-hour-label" style="top: {{ hour.top_pct }}%;">{{ hour.label }}</div>
      {% endfor %}
    </div>

    {% for day in days %}
      <div class="fcx-day-column">
        {% for hour in hours %}
          <div class="fcx-hour-line" style="top: {{ hour.top_pct }}%;"></div>
        {% endfor %}
        {% for event in day.timed_events %}
          <div
            class="fcx-event"
            style="top: {{ event.top_pct }}%; height: {{ event.height_pct }}%; left: {{ event.left_pct }}%; width: {{ event.width_pct }}%;"
          >
            <div class="fcx-event-title">{{ event.title }}</div>
            {% if show_calendar_names %}<div class="fcx-event-cal">{{ event.calendar }}</div>{% endif %}
          </div>
        {% endfor %}
      </div>
    {% endfor %}
  </div>
</div>

<style>
  html,
  body,
  * {
    box-sizing: border-box;
  }

  html,
  body {
    width: 100%;
    height: 100%;
    margin: 0;
  }

  .fcx-screen {
    width: 100%;
    height: 100vh;
    padding: 18px 28px 20px;
    color: #111;
    background: #fff;
    font-family: Arial, Helvetica, sans-serif;
    overflow: hidden;
    display: grid;
    grid-template-rows: 76px minmax(0, 1fr);
  }

  .fcx-topbar {
    display: flex;
    align-items: center;
    min-width: 0;
  }

  .fcx-title {
    font-size: 54px;
    line-height: 64px;
    font-weight: 800;
  }

  .fcx-week {
    --time-width: 76px;
    display: grid;
    grid-template-columns: var(--time-width) repeat(var(--days), minmax(0, 1fr));
    grid-template-rows: 80px 74px minmax(0, 1fr);
    border-top: 5px solid #111;
    border-left: 5px solid #111;
    border-bottom: 5px solid #111;
    min-width: 0;
    min-height: 0;
  }

  .fcx-corner,
  .fcx-day-head,
  .fcx-all-day-label,
  .fcx-all-day-cell,
  .fcx-time-labels,
  .fcx-day-column {
    border-right: 3px solid #555;
    min-width: 0;
  }

  .fcx-corner,
  .fcx-day-head {
    border-bottom: 5px solid #111;
  }

  .fcx-day-head {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 6px;
    font-size: 34px;
    line-height: 40px;
    font-weight: 800;
    overflow: hidden;
    white-space: nowrap;
  }

  .fcx-day-head.fcx-today span {
    color: #fff;
    background: #111;
    border-radius: 24px;
    padding: 8px 20px;
  }

  .fcx-all-day-label {
    border-bottom: 5px solid #111;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    font-size: 18px;
    line-height: 20px;
    font-weight: 800;
    text-transform: uppercase;
  }

  .fcx-all-day-cell {
    border-bottom: 5px solid #111;
    padding: 8px 10px;
    overflow: hidden;
  }

  .fcx-all-day-event,
  .fcx-more {
    height: 24px;
    margin-bottom: 4px;
    padding: 1px 8px;
    border: 2px solid #111;
    border-radius: 11px;
    background: #ddd;
    font-size: 17px;
    line-height: 20px;
    overflow: hidden;
    white-space: nowrap;
    text-overflow: ellipsis;
  }

  .fcx-more {
    background: #fff;
    font-weight: 800;
    text-align: center;
  }

  .fcx-time-labels,
  .fcx-day-column {
    position: relative;
    min-height: 0;
  }

  .fcx-hour-label {
    position: absolute;
    right: 12px;
    transform: translateY(-50%);
    color: #222;
    font-size: 24px;
    line-height: 28px;
    font-weight: 800;
  }

  .fcx-hour-line {
    position: absolute;
    left: 0;
    right: 0;
    border-top: 2px solid #c8c8c8;
  }

  .fcx-event {
    position: absolute;
    min-height: 24px;
    padding: 5px 8px;
    border: 2px solid #111;
    border-radius: 10px;
    background: #d0d0d0;
    overflow: hidden;
  }

  .fcx-event-title {
    font-size: 20px;
    line-height: 23px;
    font-weight: 800;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .fcx-event-cal {
    margin-top: 2px;
    font-size: 15px;
    line-height: 18px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
</style>
