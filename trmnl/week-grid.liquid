<div class="screen">
  <div class="topbar">
    <div class="title">Calendar</div>
    <div class="synced">Synced: {{ synced_label | default: "just now" }}</div>
  </div>

  <div class="week" style="--days: {{ day_count }};">
    <div class="corner"></div>
    {% for day in days %}
      <div class="day-head {% if day.is_today %}today{% endif %}">
        <span>{{ day.label }}</span>
      </div>
    {% endfor %}

    <div class="all-day-label">all-day</div>
    {% for day in days %}
      <div class="all-day-cell">
        {% for event in day.all_day_events limit:2 %}
          <div class="all-day-event">
            {% if show_calendar_names %}<b>{{ event.calendar }}</b> {% endif %}{{ event.title }}
          </div>
        {% endfor %}
        {% if day.all_day_events.size > 2 %}
          <div class="more">+{{ day.all_day_events.size | minus: 2 }}</div>
        {% endif %}
      </div>
    {% endfor %}

    <div class="time-labels">
      {% for hour in hours %}
        <div class="hour-label" style="top: {{ hour.top_pct }}%;">{{ hour.label }}</div>
      {% endfor %}
    </div>

    {% for day in days %}
      <div class="day-column">
        {% for hour in hours %}
          <div class="hour-line" style="top: {{ hour.top_pct }}%;"></div>
        {% endfor %}
        {% for event in day.timed_events %}
          <div
            class="event"
            style="top: {{ event.top_pct }}%; height: {{ event.height_pct }}%; left: {{ event.left_pct }}%; width: {{ event.width_pct }}%;"
          >
            <div class="event-title">{{ event.title }}</div>
            {% if show_calendar_names %}<div class="event-cal">{{ event.calendar }}</div>{% endif %}
          </div>
        {% endfor %}
      </div>
    {% endfor %}
  </div>
</div>

<style>
  * {
    box-sizing: border-box;
  }

  .screen {
    width: 800px;
    height: 480px;
    padding: 12px 14px;
    color: #111;
    background: #fff;
    font-family: Arial, Helvetica, sans-serif;
    overflow: hidden;
  }

  .topbar {
    height: 30px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-bottom: 2px solid #111;
  }

  .title {
    font-size: 18px;
    font-weight: 700;
  }

  .synced {
    border: 1px solid #111;
    border-radius: 8px;
    padding: 3px 8px;
    font-size: 11px;
    font-weight: 700;
    white-space: nowrap;
  }

  .week {
    --time-width: 42px;
    height: 426px;
    display: grid;
    grid-template-columns: var(--time-width) repeat(var(--days), minmax(0, 1fr));
    grid-template-rows: 38px 52px 1fr;
    border-left: 2px solid #111;
    border-bottom: 2px solid #111;
  }

  .corner,
  .day-head,
  .all-day-label,
  .all-day-cell,
  .time-labels,
  .day-column {
    border-right: 1px solid #555;
  }

  .corner,
  .day-head {
    border-bottom: 2px solid #111;
  }

  .day-head {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 4px;
    font-size: 13px;
    font-weight: 700;
  }

  .day-head.today span {
    color: #fff;
    background: #111;
    border-radius: 10px;
    padding: 4px 8px;
  }

  .all-day-label {
    border-bottom: 2px solid #111;
    padding-top: 17px;
    text-align: center;
    font-size: 9px;
    font-weight: 700;
    text-transform: uppercase;
  }

  .all-day-cell {
    border-bottom: 2px solid #111;
    padding: 3px;
    overflow: hidden;
  }

  .all-day-event,
  .more {
    height: 19px;
    margin-bottom: 2px;
    padding: 2px 4px;
    border: 1px solid #111;
    border-radius: 6px;
    background: #ddd;
    font-size: 9px;
    line-height: 13px;
    overflow: hidden;
    white-space: nowrap;
    text-overflow: ellipsis;
  }

  .more {
    background: #fff;
    font-weight: 700;
    text-align: center;
  }

  .time-labels,
  .day-column {
    position: relative;
    min-height: 0;
  }

  .hour-label {
    position: absolute;
    right: 5px;
    transform: translateY(-50%);
    color: #222;
    font-size: 9px;
    font-weight: 700;
  }

  .hour-line {
    position: absolute;
    left: 0;
    right: 0;
    border-top: 1px solid #c8c8c8;
  }

  .event {
    position: absolute;
    min-height: 14px;
    padding: 3px 4px;
    border: 1px solid #111;
    border-radius: 6px;
    background: #cfcfcf;
    overflow: hidden;
  }

  .event-title {
    font-size: 10px;
    line-height: 12px;
    font-weight: 700;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .event-cal {
    margin-top: 1px;
    font-size: 8px;
    line-height: 9px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
</style>
