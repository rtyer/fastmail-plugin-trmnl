<div class="fc-screen">
  <div class="fc-topbar">
    <div class="fc-title">Calendar</div>
    <div class="fc-synced">Synced: {{ synced_label | default: "just now" }}</div>
  </div>

  <div class="fc-week" style="--days: {{ day_count }};">
    <div class="fc-corner"></div>
    {% for day in days %}
      <div class="fc-day-head {% if day.is_today %}fc-today{% endif %}">
        <span>{{ day.label }}</span>
      </div>
    {% endfor %}

    <div class="fc-all-day-label">all-day</div>
    {% for day in days %}
      <div class="fc-all-day-cell">
        {% for event in day.all_day_events limit:2 %}
          <div class="fc-all-day-event">
            {% if show_calendar_names %}<b>{{ event.calendar }}</b> {% endif %}{{ event.title }}
          </div>
        {% endfor %}
        {% if day.all_day_events.size > 2 %}
          <div class="fc-more">+{{ day.all_day_events.size | minus: 2 }}</div>
        {% endif %}
      </div>
    {% endfor %}

    <div class="fc-time-labels">
      {% for hour in hours %}
        <div class="fc-hour-label" style="top: {{ hour.top_pct }}%;">{{ hour.label }}</div>
      {% endfor %}
    </div>

    {% for day in days %}
      <div class="fc-day-column">
        {% for hour in hours %}
          <div class="fc-hour-line" style="top: {{ hour.top_pct }}%;"></div>
        {% endfor %}
        {% for event in day.timed_events %}
          <div
            class="fc-event"
            style="top: {{ event.top_pct }}%; height: {{ event.height_pct }}%; left: {{ event.left_pct }}%; width: {{ event.width_pct }}%;"
          >
            <div class="fc-event-title">{{ event.title }}</div>
            {% if show_calendar_names %}<div class="fc-event-cal">{{ event.calendar }}</div>{% endif %}
          </div>
        {% endfor %}
      </div>
    {% endfor %}
  </div>
</div>

<style>
  * {
    box-sizing: border-box;
  }

  .fc-screen {
    width: 100%;
    height: 100%;
    min-height: 440px;
    padding: 6px 8px;
    color: #111;
    background: #fff;
    font-family: Arial, Helvetica, sans-serif;
    overflow: hidden;
    display: grid;
    grid-template-rows: 28px minmax(0, 1fr);
    gap: 0;
  }

  .fc-topbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-bottom: 2px solid #111;
    min-width: 0;
  }

  .fc-title {
    font-size: 18px;
    font-weight: 700;
    line-height: 22px;
  }

  .fc-synced {
    border: 1px solid #111;
    border-radius: 8px;
    padding: 2px 7px;
    font-size: 10px;
    font-weight: 700;
    white-space: nowrap;
  }

  .fc-week {
    --time-width: 38px;
    display: grid;
    grid-template-columns: var(--time-width) repeat(var(--days), minmax(0, 1fr));
    grid-template-rows: 28px 46px minmax(0, 1fr);
    border-left: 2px solid #111;
    border-bottom: 2px solid #111;
    min-width: 0;
    min-height: 0;
  }

  .fc-corner,
  .fc-day-head,
  .fc-all-day-label,
  .fc-all-day-cell,
  .fc-time-labels,
  .fc-day-column {
    border-right: 1px solid #555;
    min-width: 0;
  }

  .fc-corner,
  .fc-day-head {
    border-bottom: 2px solid #111;
  }

  .fc-day-head {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2px;
    font-size: 11px;
    font-weight: 700;
    line-height: 14px;
    overflow: hidden;
    white-space: nowrap;
  }

  .fc-day-head.fc-today span {
    color: #fff;
    background: #111;
    border-radius: 10px;
    padding: 3px 7px;
  }

  .fc-all-day-label {
    border-bottom: 2px solid #111;
    padding-top: 15px;
    text-align: center;
    font-size: 8px;
    font-weight: 700;
    text-transform: uppercase;
  }

  .fc-all-day-cell {
    border-bottom: 2px solid #111;
    padding: 2px;
    overflow: hidden;
  }

  .fc-all-day-event,
  .fc-more {
    height: 17px;
    margin-bottom: 2px;
    padding: 1px 3px;
    border: 1px solid #111;
    border-radius: 5px;
    background: #ddd;
    font-size: 8px;
    line-height: 13px;
    overflow: hidden;
    white-space: nowrap;
    text-overflow: ellipsis;
  }

  .fc-more {
    background: #fff;
    font-weight: 700;
    text-align: center;
  }

  .fc-time-labels,
  .fc-day-column {
    position: relative;
    min-height: 0;
  }

  .fc-hour-label {
    position: absolute;
    right: 5px;
    transform: translateY(-50%);
    color: #222;
    font-size: 8px;
    font-weight: 700;
  }

  .fc-hour-line {
    position: absolute;
    left: 0;
    right: 0;
    border-top: 1px solid #c8c8c8;
  }

  .fc-event {
    position: absolute;
    min-height: 12px;
    padding: 2px 3px;
    border: 1px solid #111;
    border-radius: 5px;
    background: #cfcfcf;
    overflow: hidden;
  }

  .fc-event-title {
    font-size: 9px;
    line-height: 10px;
    font-weight: 700;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .fc-event-cal {
    margin-top: 1px;
    font-size: 7px;
    line-height: 8px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
</style>
